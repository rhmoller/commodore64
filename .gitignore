# build artifacts (regenerate with petcat / the assembler)
*.prg
*.d64
*.d71
*.d81
*.t64
*.crt
# KickAssembler VICE debug symbols
*.vs

# Large, re-downloadable reference: the Programmer's Reference Guide PDF is ~45 MB.
# The searchable .txt is kept; re-fetch the PDF per docs/reference/README.md.
docs/reference/*.pdf

# tooling / scratch
.playwright-mcp/
.botface/
__pycache__/
*.pyc
# Node (debugger dev deps for type-checking only; runtime needs none)
node_modules/
*.tsbuildinfo
# capstone build agents may drop a temp source at the repo root; the canonical
# listing lives in the docs page.
/tmp_*.asm

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*~

# local scratch / playground (build artifacts already ignored)
useit/
