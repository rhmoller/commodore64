{
  "name": "vice-web-debugger",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Browser C64 remote-dev IDE + VICE debugger. Server (Node, zero runtime deps) bridges WebSocket ⇄ binary monitor and serves a Vite/React/CodeMirror UI.",
  "engines": { "node": ">=22.6" },
  "scripts": {
    "server": "node src/server.ts",
    "start": "node src/server.ts",
    "dev:ui": "vite -c src-ui/vite.config.ts",
    "dev:server": "node src/server.ts",
    "dev": "concurrently -k -n server,vite -c blue,magenta \"npm:dev:server\" \"npm:dev:ui\"",
    "build": "vite build -c src-ui/vite.config.ts",
    "preview": "vite preview -c src-ui/vite.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src-ui/tsconfig.json"
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.34.0",
    "@lezer/highlight": "^1.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  }
}
